# =============================================================================
# Điểm danh sinh hoạt hè — biến môi trường mẫu
# Sao chép file này thành `.env.local` và điền giá trị thật.
# KHÔNG commit `.env.local`. KHÔNG hardcode secret trong mã nguồn.
# =============================================================================

# --- Supabase (public, được nhúng vào client) ---
NEXT_PUBLIC_SUPABASE_URL=
# Khóa publishable mới của Supabase (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# (Tùy chọn) Tên cũ — vẫn được đọc để backward-compat nếu chưa đổi sang tên mới.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, TUYỆT ĐỐI không expose ra client) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Ứng dụng ---
APP_BASE_URL=http://localhost:3000

# --- Bootstrap tài khoản DEMO (chỉ local/dev, chạy `npm run bootstrap:auth`) ---
# Mật khẩu dùng cho các tài khoản demo. Bỏ trống -> script tự sinh ngẫu nhiên & in ra.
# KHÔNG dùng mật khẩu thật ở đây.
# DEMO_USER_PASSWORD=

# --- Bảo mật nội bộ (bật ở phase sau) ---
# AUDIT_LOG_SECRET=

# --- Storage buckets (phase import/export) ---
# DOCX_TEMPLATE_BUCKET=docx-templates
# IMPORT_BUCKET=imports

# --- AI import (Gemini Vision, server-only, TUYỆT ĐỐI không expose ra client) ---
# Đọc ảnh giấy tờ → dòng học sinh NHÁP để duyệt tay. Lấy key: https://aistudio.google.com/apikey
# ĐIỀN GIÁ TRỊ THẬT Ở `.env.local` (KHÔNG điền key thật vào file mẫu — nó được commit!).
# Thiếu key hoặc AI_IMPORT_ENABLED=false -> nút AI tắt, NHẬP TAY vẫn chạy bình thường.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
AI_IMPORT_MAX_FILE_MB=4
AI_IMPORT_ENABLED=true
# Giới hạn số lượt AI đọc ảnh / người dùng / ngày (bảo vệ quota Gemini).
AI_IMPORT_DAILY_LIMIT=50

# --- Auth bootstrap ---
# ALLOW_DEMO_AUTH_SEED=false
