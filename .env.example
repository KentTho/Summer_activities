# =============================================================================
# Điểm danh sinh hoạt hè — biến môi trường mẫu
# Sao chép file này thành `.env.local` và điền giá trị thật.
# KHÔNG commit `.env.local`. KHÔNG hardcode secret trong mã nguồn.
# =============================================================================

# --- Supabase (public, được nhúng vào client) ---
NEXT_PUBLIC_SUPABASE_URL=
# Khóa publishable mới của Supabase (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# (Tùy chọn) Tên cũ — vẫn được đọc để backward-compat nếu chưa đổi sang tên mới.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, TUYỆT ĐỐI không expose ra client) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Ứng dụng ---
APP_BASE_URL=http://localhost:3000

# --- Bootstrap tài khoản DEMO (chỉ local/dev, chạy `npm run bootstrap:auth`) ---
# Mật khẩu dùng cho các tài khoản demo. Bỏ trống -> script tự sinh ngẫu nhiên & in ra.
# KHÔNG dùng mật khẩu thật ở đây.
# DEMO_USER_PASSWORD=

# --- Bảo mật nội bộ (bật ở phase sau) ---
# AUDIT_LOG_SECRET=

# --- Storage buckets (phase import/export) ---
# DOCX_TEMPLATE_BUCKET=docx-templates
# IMPORT_BUCKET=imports

# --- OCR provider (server-only, TUYỆT ĐỐI không expose ra client) ---
# Provider mặc định: OCR.space Free OCR API. Lấy key free tại https://ocr.space/ocrapi
# ĐIỀN GIÁ TRỊ THẬT Ở `.env.local` (KHÔNG điền key thật vào file mẫu này — nó được commit!).
# Thiếu key -> UI/flow import vẫn chạy nhưng KHÔNG gọi OCR (báo cần cấu hình).
OCR_PROVIDER=ocrspace
OCR_SPACE_API_KEY=
# (Tùy chọn) Ghi đè endpoint / ngôn ngữ / engine. vie = tiếng Việt; engine 1 giữ dấu tốt hơn.
# OCR_SPACE_API_URL=https://api.ocr.space/parse/image
# OCR_SPACE_LANGUAGE=vie
# OCR_SPACE_ENGINE=1

# --- Optional future providers (chưa bật; để tham khảo) ---
# GOOGLE_CLOUD_VISION_API_KEY=
# GEMINI_API_KEY=

# --- Auth bootstrap ---
# ALLOW_DEMO_AUTH_SEED=false
